# FraudLens Claims AI
# No incluir credenciales reales.

APP_ENV=local
DB_BACKEND=mysql
SYNTHETIC_DATA_DIR=data/synthetic
PROCESSED_DATA_DIR=data/processed

# MySQL local de demo.
# No escribir credenciales productivas en este archivo.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root

# Dos bases separadas. El agente y el MCP consultan ambas.
MYSQL_DATABASE=fraudlens_claims_ai
MYSQL_WATCHLIST_DATABASE=fraudlens_watchlist
